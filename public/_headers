/*
  Cloudflare Pages: keep HTML fresh so phones pick up new deployments.
  Hashed /assets/* files stay long-cached (Vite content hashes).
*/

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
